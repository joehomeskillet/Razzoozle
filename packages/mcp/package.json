{
  "name": "@razzoozle/mcp",
  "type": "module",
  "private": true,
  "description": "Project-scoped MCP (Model Context Protocol) stdio server for the Rahoot/Razzia quiz app: author quizzes (incl. AI images), control a live game, and act as game master.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node esbuild.config.js",
    "start": "node dist/index.cjs",
    "types": "tsc --noEmit",
    "format": "prettier --check . --log-level warn",
    "format:fix": "prettier --write . --log-level warn"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.3",
    "@razzoozle/common": "link:../common",
    "socket.io-client": "^4.8.3",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0"
  }
}
