    "socket.io": "^4.8.3",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
