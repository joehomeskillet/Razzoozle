{
  "$schema": "https://tokens.studio/schema/draft.json",
  "$metadata": {
    "tokenSetOrder": ["brand", "fields", "surfaces", "radius", "text", "console", "answer-tiles", "teams", "tiers", "state", "misc", "labels", "typography", "spacing", "scrim"],
    "convertedDate": "2026-07-22",
    "reconciliation": "DTCG design.tokens.json is now the single source of truth. Older .design-tokens.json (2026-07-17) should be regenerated from this file; do not edit .design-tokens.json directly.",
    "sourceFiles": ["design.md", "packages/web/src/index.css", "packages/web/src/features/manager/components/console/tokens.css"]
  },
  "brand": {
    "primary": {
      "$value": "#7c3aed",
      "$type": "color",
      "$description": "Violet brand color. Primary CTA, pinned in console. White text OK."
    },
    "secondary": {
      "$value": "#2e1065",
      "$type": "color",
      "$description": "Dark ink, headings. Pinned in console."
    },
    "accent": {
      "$value": "#ff9900",
      "$type": "color",
      "$description": "Amber accent default. RUNTIME-themeable. Canonical default is amber; set in packages/common/types/theme.ts + validators/theme.ts"
    }
  },
  "fields": {
    "cream": {
      "$value": "#F4F1EA",
      "$type": "color",
      "$description": "Front-of-house background. STATIC (:root-only). Cream field for landing, lobby, player phone, trophies, join/auth."
    },
    "ink": {
      "$value": "#0E1120",
      "$type": "color",
      "$description": "Stage background (shared result /r/:id). STATIC (:root-only). Manager/display/podium/recap now cream-converted via GameWrapper force."
    }
