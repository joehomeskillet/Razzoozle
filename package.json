{
  "name": "razzoozle",
  "version": "1.2.0",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "dotenv -e .env -- pnpm -r --parallel dev",
    "dev:web": "dotenv -e .env -- pnpm --filter web dev",
    "dev:socket": "dotenv -e .env -- pnpm --filter socket dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel run start",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "pnpm -r --parallel run types && oxlint",
    "test": "pnpm -r --if-present run test",
    "verify": "pnpm -r run types && oxlint && pnpm -r --if-present run test",
    "format": "pnpm -r --parallel run format",
    "format:fix": "pnpm -r --parallel run format:fix"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "latest",
    "dotenv-cli": "^11.0.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  }
}
