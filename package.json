{
  "name": "razzoozle",
  "version": "3.0.0",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "dotenv -e .env -- pnpm -r --parallel dev",
    "dev:web": "dotenv -e .env -- pnpm --filter web dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel run start",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "pnpm -r --parallel run types && oxlint",
    "test": "pnpm -r --if-present run test",
    "verify": "pnpm -r run types && oxlint && pnpm -r --if-present run test",
    "format": "pnpm -r --parallel run format",
    "format:fix": "pnpm -r --parallel run format:fix",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "i18n:check": "i18n-check -l packages/web/src/locales -s de -f i18next",
    "i18n:report": "i18n-check -l packages/web/src/locales -s de -f i18next -o unused,undefined -u packages/web/src"
  },
  "devDependencies": {
    "@lingual/i18n-check": "0.9.5",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "latest",
    "@types/node": "^26.1.0",
    "dotenv-cli": "^11.0.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
